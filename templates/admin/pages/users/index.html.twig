{% extends 'admin/pages/users/template.html.twig' %}

{% set page_title %}Utilisateurs{% endset %}
{% set page_subtitle %}Ajouter et gérez les utilisateurs du site.{% endset %}

{% set page_actions %}
    {% include 'layout/components/common/buttons/button.html.twig' with {
        btn_link: path('admin_users_create'),
        btn_type: 'blue',
        btn_icon: 'add',
        btn_text: 'Ajouter un utilisateur'
    } %}
    <div id="users_export">
        {% include "layout/components/common/loaders/btn_icon.html.twig" %}
    </div>
{% endset %}

{% block main_content %}
    <div id="users_list" data-highlight="{{ highlight }}">
        {% include "layout/components/common/loaders/loader.html.twig" %}
    </div>
{% endblock %}
